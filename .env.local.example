# AEX Next.js — Environment Variables
# Copy this file to .env.local and fill in your values

# ── SMTP / Email Configuration (for contact & enquiry forms) ──────────────────
# Uncomment these and fill in when you're ready to send real emails.
# The forms currently log submissions to the server console (no SMTP needed for dev).

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Email address that receives contact form submissions
# CONTACT_EMAIL=tech@aexheatshrink.com

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
