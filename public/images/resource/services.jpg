          <h2 class="field__label">Staff</h2>
    
      <div class="field field--name-field-content field--type-entity-reference field--label-hidden field__items">
              <div class="field__item">

<article role="article" class="node node--type-profile node--view-mode-sidebar">

  <div class="node__content">

    <div class="row my-3 my-sm-4">

      <div class="sidebar-links">

